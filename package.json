{
  "name": "nexus-gestao",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:frontend",
    "dev:frontend": "vite --config frontend/vite.config.ts --host 0.0.0.0",
    "dev:backend": "tsx watch backend/src/server.ts",
    "build": "npm run build:backend && npm run build:frontend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build:backend": "tsc -p backend/tsconfig.json",
    "start": "node backend/dist/server.js",
    "preview": "vite preview --config frontend/vite.config.ts",
    "prisma:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "prisma:seed": "tsx backend/prisma/seed.ts",
    "lint": "tsc -p backend/tsconfig.json --noEmit && tsc -p frontend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.0",
    "@prisma/client": "^6.15.0",
    "@vitejs/plugin-react": "^5.0.2",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.1.0",
    "framer-motion": "^12.23.12",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.542.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.10",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "react-router-dom": "^7.8.2",
    "recharts": "^3.1.2",
    "sonner": "^2.0.7",
    "vite": "^7.1.4",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.3.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "prisma": "^6.15.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
